# Database (Supabase PostgreSQL)
DATABASE_URL="postgresql://postgres:password@localhost:5432/carrierflow"
DIRECT_URL="postgresql://postgres:password@localhost:5432/carrierflow"

# Supabase Storage (server-side only)
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
STORAGE_PROVIDER=local

# Auth.js (free, self-hosted) — generate secret: openssl rand -base64 32
AUTH_SECRET=
AUTH_URL=http://localhost:3000
# Optional Google OAuth (https://console.cloud.google.com)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
# Email verification — set true in E2E only; production sends Resend links
AUTO_VERIFY_EMAIL=false
# Admin MFA — set true to require TOTP enrollment before admin dashboard (default false)
REQUIRE_ADMIN_MFA=false
# Dev admin password (seed creates admin@carrierflow.local)
SEED_ADMIN_PASSWORD=changeme123

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL_INTERVIEW=gpt-4o
OPENAI_MODEL_DOCUMENT=gpt-4o
OPENAI_MODEL_VERIFICATION=gpt-4o
OPENAI_MODEL_RISK=gpt-4o
OPENAI_MODEL_APPROVAL=gpt-4o

# FMCSA QCMobile
FMCSA_WEB_KEY=

# Inngest — see docs/DEPLOY.md §4. Required for compliance crons + document jobs.
# Create app at https://www.inngest.com/, set serve URL to https://<domain>/api/inngest
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Local storage (dev)
LOCAL_STORAGE_PATH=.data/uploads

# Email (Phase 2 — Resend)
RESEND_API_KEY=
EMAIL_FROM=CarrierFlow <onboarding@yourdomain.com>
NEXT_PUBLIC_APP_URL=http://localhost:3000
COMPLIANCE_ALERT_EMAILS=ops@fabuwood.com
# Onboarding idle reminders (Inngest cron Mondays 9:00 UTC + manual admin trigger)
# ONBOARDING_REMINDER_IDLE_DAYS=7

# Compliance monitoring
COMPLIANCE_CSA_THRESHOLD=75

# Fraud vetting
FRAUD_BLOCK_THRESHOLD=60
IDENTITY_AUTO_PASS_CONFIDENCE=0.92
IDENTITY_HARD_FAIL_CONFIDENCE=0.4

# Phone verification (VoIP / disposable detection) — optional, no-ops when unset
# PHONE_VERIFY_PROVIDER: stub | twilio | numverify (default stub)
# Twilio: set PHONE_VERIFY_API_KEY to AccountSid:AuthToken
PHONE_VERIFY_API_KEY=
PHONE_VERIFY_PROVIDER=stub

# TIN / legal name match — optional commercial provider, no-ops when unset
# TIN_VERIFY_PROVIDER: stub | taxidpro | sovos (default stub)
# IRS has no public API; use a commercial TIN matching service when enabled
TIN_VERIFY_API_KEY=
TIN_VERIFY_PROVIDER=stub

# Observability (optional)
SENTRY_DSN=
